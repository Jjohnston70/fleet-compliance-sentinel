PENNY_API_VERSION=0.1.0
PENNY_API_KEY=replace-with-strong-shared-secret
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_MAX_TOKENS=4000
ENABLE_GENERAL_FALLBACK=true
ANTHROPIC_GENERAL_FALLBACK_MODEL=claude-sonnet-4-6
ANTHROPIC_GENERAL_FALLBACK_MAX_TOKENS=1800
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=4000
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MAX_TOKENS=4000
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.1
OLLAMA_MAX_TOKENS=4000
MAX_QUERY_CHARS=2500
FALLBACK_MAX_CHARS=6000
CORS_ORIGINS=https://pipelinepunks.com,https://www.pipelinepunks.com
KNOWLEDGE_STORE_PATH=./data/knowledge.json

# Verizon Connect Reveal telematics integration
REVEAL_USERNAME=
REVEAL_PASSWORD=
