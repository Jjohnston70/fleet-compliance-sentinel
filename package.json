{
  "name": "tnds-pipelinex-v2",
  "version": "1.0.0",
  "private": true,
  "description": "True North Data Strategies — PipelineX product site",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "npm run preflight:skill-packs && tsx scripts/build-cfr-index.mjs && next build",
    "start": "next start",
    "lint": "next lint",
    "preflight:skill-packs": "tsx scripts/preflight-skill-packs.ts",
    "test:onboarding-phase1": "tsx --test src/lib/onboarding/*.test.ts",
    "test:onboarding-drift": "tsx --test src/lib/onboarding/contract-drift.test.ts",
    "docs:vendors": "node scripts/download-vendor-docs.mjs",
    "docs:vendors:prepare": "node scripts/prepare-vendor-docs-package.mjs",
    "docs:vendors:package": "npm run docs:vendors && npm run docs:vendors:prepare",
    "compliance:legal-check": "node scripts/check-legal-pages.mjs",
    "compliance:ops-check": "node scripts/ops-check.mjs",
    "db:check-training-schema": "node scripts/check-training-schema.mjs",
    "sync:knowledge": "node scripts/sync-local-knowledge.mjs",
    "build:cfr-index": "tsx scripts/build-cfr-index.mjs",
    "eval:penny": "node scripts/run-penny-evals.mjs",
    "test:onboarding-alerts": "tsx --test src/lib/onboarding/alert-binding.test.ts",
    "test:onboarding-phase6": "tsx --test src/lib/onboarding/phase6-release-gate.test.ts"
  },
  "dependencies": {
    "@clerk/nextjs": "^7.0.8",
    "@neondatabase/serverless": "^1.0.2",
    "@opentelemetry/instrumentation": "^0.57.2",
    "@opentelemetry/instrumentation-http": "^0.57.2",
    "@sentry/nextjs": "^10.46.0",
    "@tnds/ingest-core": "*",
    "@tnds/memory-core": "*",
    "@tnds/retrieval-core": "*",
    "@tnds/types": "*",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "cheerio": "^1.2.0",
    "csv-parse": "^6.1.0",
    "docx": "^8.5.0",
    "exceljs": "^4.4.0",
    "handlebars": "^4.7.9",
    "mammoth": "^1.11.0",
    "next": "^15.5.14",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^2.4.5",
    "pg": "^8.20.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "recharts": "^2.15.4",
    "remark-gfm": "^4.0.1",
    "stripe": "^21.0.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^20.19.0",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.2.17",
    "autoprefixer": "^10.4.24",
    "eslint": "^8.55.0",
    "eslint-config-next": "^15.5.14",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.19.0",
    "typescript": "^5.3.3"
  },
  "optionalDependencies": {
    "@esbuild/linux-x64": "^0.28.0"
  }
}
