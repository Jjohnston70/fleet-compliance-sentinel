# Email Command Configuration

# Firestore (optional if using Firebase)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY=your-private-key
FIREBASE_CLIENT_EMAIL=your-client-email@firebase.iam.gserviceaccount.com

# Email Configuration
DEFAULT_TIMEZONE=America/Denver
DEFAULT_ANOMALY_THRESHOLD=2.0

# Branding
PRIMARY_COLOR=#0077cc
SECONDARY_COLOR=#333333
ACCENT_COLOR=#ff9900

# Digest Settings
ENABLE_DAILY_DIGEST=true
ENABLE_WEEKLY_DIGEST=true
ENABLE_MONTHLY_DIGEST=true
ENABLE_QUARTERLY_DIGEST=true
ENABLE_ALERT_DIGEST=true

# Default recipient email (override per user)
DEFAULT_RECIPIENT_EMAIL=notifications@example.com
