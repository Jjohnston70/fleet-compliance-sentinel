# Training Command Service Configuration

# Platform
PLATFORM_NAME=True North AI Academy
PLATFORM_EMAIL=support@truenorthai.com

# Database (for future use with actual persistence)
DATABASE_URL=postgresql://user:password@localhost:5432/training-command

# Email Service
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASSWORD=

# Timezone
DEFAULT_TIMEZONE=America/New_York

# Feature Flags
ENABLE_CERTIFICATIONS=true
ENABLE_CONSULTATIONS=true
ENABLE_WORKSHOPS=true

# Pricing
MONTHLY_BASIC_PRICE_CENTS=4900
MONTHLY_PROFESSIONAL_PRICE_CENTS=9900
MONTHLY_ENTERPRISE_PRICE_CENTS=49900

# Analytics
LOG_LEVEL=info
ENABLE_ANALYTICS=true
