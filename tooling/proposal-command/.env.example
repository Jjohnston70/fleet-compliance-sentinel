# Firebase Configuration
FIREBASE_PROJECT_ID=tnds-proposal-module
FIREBASE_API_KEY=your-firebase-api-key
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_DATABASE_URL=https://your-project.firebaseio.com
FIREBASE_STORAGE_BUCKET=your-project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your-sender-id
FIREBASE_APP_ID=your-app-id

# Email Service Configuration (Resend)
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM_NAME=True North Strategy Ops
EMAIL_FROM_EMAIL=proposals@truenorthstrategyops.com
EMAIL_REPLY_TO=sales@truenorthstrategyops.com
EMAIL_ADMIN_EMAIL=admin@truenorthstrategyops.com
EMAIL_CC_ADMIN=true

# Company Branding
COMPANY_NAME=True North Strategy Ops
COMPANY_WEBSITE=https://truenorthstrategyops.com
COMPANY_PHONE=(555) 123-4567
COMPANY_ADDRESS=123 Main Street, Suite 100, Chicago, IL 60601
COMPANY_LOGO_URL=https://truenorthstrategyops.com/logo.png

# Application Settings
APP_URL=http://localhost:3000
TIMEZONE=America/Chicago
NODE_ENV=development
