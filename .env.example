# Clerk Authentication
# Local dev: use pk_test/sk_test keys from a Clerk Development instance.
# Production (Vercel): use pk_live/sk_live keys for your production domain.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxx
CLERK_SECRET_KEY=sk_test_xxxxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/penny
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/penny

# Pipeline Penny Backend
PENNY_API_URL=http://localhost:8000
# Shared secret used by Vercel API routes when calling Railway backend
PENNY_API_KEY=
# Allow Penny requests without an active Clerk organization.
# Production default is false; non-production defaults to true if unset.
PENNY_ALLOW_NO_ORG=false
# Max number of general-knowledge fallbacks per authenticated browser session
PENNY_GENERAL_FALLBACK_SESSION_LIMIT=3
# Optional: enable distributed Penny query rate limiting in production (recommended on Vercel)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Neon Postgres (Vercel Postgres integration)
# Set automatically when you link a Neon database in the Vercel dashboard.
# For local dev, copy the connection string from your Neon project settings.
DATABASE_URL=

# Railway Penny CORS lock-down (configure in Railway dashboard for backend service)
CORS_ORIGINS=https://www.pipelinepunks.com,https://pipelinepunks.com

# Optional existing webhook integration
GOOGLE_SHEET_WEBHOOK_URL=
STRIPE_WEBHOOK_SECRET=
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_STARTER_PRICE_ID=
STRIPE_PRO_PRICE_ID=

# Existing site URL for metadata/sitemap
SITE_URL=https://truenorthstrategyops.com

# Fleet-Compliance Alerts
# Resend API key for sending compliance reminder emails.
# If not set, the alert sweep runs in dry-run mode (no emails sent).
RESEND_API_KEY=

# Verified sender address in your Resend account.
FLEET_COMPLIANCE_ALERT_FROM_EMAIL=compliance@fleetcompliance.com

# Secret used to authorize POST calls to /api/fleet-compliance/alerts/run.
# Vercel Cron sends this as: Authorization: Bearer <secret>
FLEET_COMPLIANCE_CRON_SECRET=

# Optional display name used in email subjects and bodies.
FLEET_COMPLIANCE_ORG_NAME=Fleet Compliance

# FMCSA Query Central API key — get a free key at https://ai.fmcsa.dot.gov/SMS/Tools/Downloads.aspx
# Required for /api/fleet-compliance/fmcsa/lookup and /fleet-compliance/fmcsa carrier lookup page.
FMCSA_API_KEY=
