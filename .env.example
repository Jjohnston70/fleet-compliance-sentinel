############################################
# Telematics (Verizon Connect Reveal)
############################################
TELEMATICS_CRON_SECRET=replace-with-long-random-secret
RAILWAY_SYNC_URL=https://pipeline-punks-v2-production.up.railway.app

# Telematics demo mode: set to "true" to show demo data instead of live Verizon data.
# Set to "false" or remove to restore live Verizon Reveal connection.
TELEMATICS_DEMO_MODE=true

# Used by integration scripts and Railway telematics adapter
REVEAL_ORG_ID=example-fleet-co
REVEAL_USERNAME=
REVEAL_PASSWORD=
REVEAL_APP_ID=
APP_ENCRYPTION_KEY=replace-with-32-byte-hex-or-base64
REVEAL_WEBHOOKS_ENABLED=false
REVEAL_WEBHOOK_SECRET=
REVEAL_WEBHOOK_ALLOWED_IPS=

############################################
# Railway Penny Backend (.env on Railway service)
############################################
PENNY_API_VERSION=0.1.0
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_MAX_TOKENS=4000
ENABLE_GENERAL_FALLBACK=true
ANTHROPIC_GENERAL_FALLBACK_MODEL=claude-sonnet-4-6
ANTHROPIC_GENERAL_FALLBACK_MAX_TOKENS=1800
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=4000
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MAX_TOKENS=4000
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.1
OLLAMA_MAX_TOKENS=4000
MAX_QUERY_CHARS=2500
FALLBACK_MAX_CHARS=6000
ORG_CONTEXT_MAX_CHARS=8000
CORS_ORIGINS=https://www.pipelinepunks.com,https://pipelinepunks.com
KNOWLEDGE_STORE_PATH=./data/knowledge.json

############################################
# Tooling / Ops Scripts (Optional)
############################################
KNOWLEDGE_ROOT=
KNOWLEDGE_CATEGORIES=
KNOWLEDGE_BATCH_SIZE=20
KNOWLEDGE_MAX_CHARS=18000
KNOWLEDGE_FILE_LIMIT=200
KNOWLEDGE_REPLACE=false
RAILWAY_DOCS_REPO_DIR=
RAILWAY_CHUNK_MAX_CHARS=3500
RAILWAY_CHUNK_MIN_CHARS=1200
VENDOR_DOCS_TIMEOUT_MS=30000
VENDOR_DOCS_MAX_PER_VENDOR=200
VENDOR_DOCS_CONCURRENCY=6
VENDOR_DOCS_INCLUDE=sentry,datadog,slack
VENDOR_PACKAGE_CHUNK_MAX_CHARS=3200
